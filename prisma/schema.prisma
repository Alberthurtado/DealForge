generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model Cliente {
  id           String       @id @default(cuid())
  nombre       String
  ruc          String?
  email        String?
  telefono     String?
  direccion    String?
  ciudad       String?
  pais         String?
  sector       String?
  notas        String?
  usuarioId    String
  usuario      Usuario      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  equipoId     String?
  equipo       Empresa?     @relation("ClienteEquipo", fields: [equipoId], references: [id])
  contactos    Contacto[]
  cotizaciones Cotizacion[]
  contratos    Contrato[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([usuarioId])
  @@index([equipoId])
}

model Contacto {
  id        String   @id @default(cuid())
  nombre    String
  cargo     String?
  email     String?
  telefono  String?
  principal Boolean  @default(false)
  clienteId String
  cliente   Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Categoria {
  id        String     @id @default(cuid())
  nombre    String     @unique
  productos Producto[]
}

model Producto {
  id          String              @id @default(cuid())
  nombre      String
  descripcion String?
  sku         String
  precioBase  Float
  unidad      String              @default("unidad")
  activo          Boolean             @default(true)
  tipoFacturacion String              @default("UNICO")  // UNICO | RECURRENTE
  frecuencia      String?             // MENSUAL | TRIMESTRAL | ANUAL (null si UNICO)
  categoriaId     String?
  categoria   Categoria?          @relation(fields: [categoriaId], references: [id])
  usuarioId   String
  usuario     Usuario             @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  equipoId    String?
  equipo      Empresa?            @relation("ProductoEquipo", fields: [equipoId], references: [id])
  variantes   VarianteProducto[]
  lineItems   LineItem[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@unique([sku, usuarioId])
  @@index([usuarioId])
  @@index([equipoId])
}

model VarianteProducto {
  id             String     @id @default(cuid())
  productoId     String
  producto       Producto   @relation(fields: [productoId], references: [id], onDelete: Cascade)
  nombre         String
  sku            String
  precioOverride Float?
  atributos      String     @default("{}")
  activo         Boolean    @default(true)
  lineItems      LineItem[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@unique([sku, productoId])
}

model Cotizacion {
  id               String      @id @default(cuid())
  numero           String
  clienteId        String
  cliente          Cliente     @relation(fields: [clienteId], references: [id])
  usuarioId        String
  usuario          Usuario     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  equipoId         String?
  equipo           Empresa?    @relation("CotizacionEquipo", fields: [equipoId], references: [id])
  estado           String      @default("BORRADOR")
  fechaEmision     DateTime    @default(now())
  fechaVencimiento DateTime?
  contactoNombre   String?
  subtotal         Float       @default(0)
  descuentoGlobal  Float       @default(0)
  impuesto         Float       @default(0)
  total            Float       @default(0)
  moneda           String      @default("EUR")
  notas            String?
  condiciones      String?
  version          Int         @default(1)
  lineItems        LineItem[]
  actividades      Actividad[]
  aprobaciones     Aprobacion[]
  recordatorios    Recordatorio[]
  firmas           Firma[]
  contratos        Contrato[]
  cotizacionOriginalId  String?
  cotizacionOriginal    Cotizacion?  @relation("Versiones", fields: [cotizacionOriginalId], references: [id])
  versiones             Cotizacion[] @relation("Versiones")
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@unique([numero, usuarioId])
  @@index([usuarioId])
  @@index([equipoId])
  @@index([cotizacionOriginalId])
}

model LineItem {
  id             String            @id @default(cuid())
  cotizacionId   String
  cotizacion     Cotizacion        @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  productoId     String?
  producto       Producto?         @relation(fields: [productoId], references: [id])
  varianteId     String?
  variante       VarianteProducto? @relation(fields: [varianteId], references: [id])
  descripcion    String
  cantidad       Float             @default(1)
  precioUnitario Float
  descuento      Float             @default(0)
  frecuencia     String?           // MENSUAL | TRIMESTRAL | ANUAL | null (hereda de producto)
  total          Float
  orden          Int               @default(0)
  createdAt      DateTime          @default(now())
}

model Actividad {
  id             String     @id @default(cuid())
  cotizacionId   String
  cotizacion     Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  tipo           String
  descripcion    String
  estadoAnterior String?
  estadoNuevo    String?
  createdAt      DateTime   @default(now())
}

model ReglaComercial {
  id            String   @id @default(cuid())
  nombre        String
  tipo          String   // LIMITE_DESCUENTO | PRODUCTO_OBLIGATORIO | APROBACION | PROMOCION
  activa        Boolean  @default(true)
  prioridad     Int      @default(0)
  configuracion String   // JSON text
  usuarioId     String
  usuario       Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  equipoId      String?
  equipo        Empresa? @relation("ReglaEquipo", fields: [equipoId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([usuarioId])
  @@index([equipoId])
}

model Aprobacion {
  id              String     @id @default(cuid())
  cotizacionId    String
  cotizacion      Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  reglaId         String
  aprobadorNombre String
  aprobadorEmail  String
  estado          String     @default("PENDIENTE")
  comentario      String?
  token           String?    @unique
  emailEnviadoAt  DateTime?
  respondidoAt    DateTime?
  createdAt       DateTime   @default(now())
}

model Empresa {
  id            String   @id @default(cuid())
  nombre        String   @default("Mi Empresa")
  cif           String?
  email         String?
  telefono      String?
  direccion     String?
  ciudad        String?
  pais          String?
  web           String?
  logoUrl       String?
  plantillaPdf      String   @default("moderna")
  colorPrimario     String   @default("#3a9bb5")
  prefijoCotizacion String   @default("COT")
  diasVencimiento   Int      @default(30)
  condicionesDefecto    String?  // Legacy — kept for backward compat
  condicionesTransaccional String? // T&C for one-time/transactional items
  condicionesContractual   String? // T&C for recurring/contract items
  smtpHost          String?
  smtpPort          Int?     @default(587)
  smtpUser          String?
  smtpPass          String?
  smtpSecure        Boolean  @default(false)
  // Reminder settings
  recordatorioSeguimientoDias  Int      @default(3)
  recordatorioVencimientoDias  Int      @default(3)
  recordatoriosActivos         Boolean  @default(true)
  // Plan & billing (team-level)
  plan                 String   @default("starter")
  planStatus           String   @default("active")  // active | past_due | canceled | canceling
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?
  stripePriceId        String?
  currentPeriodEnd     DateTime?
  // Relations
  usuarios          Usuario[]
  miembros          EquipoMembro[]
  invitaciones      Invitacion[]
  // Business data relations (via equipoId)
  clientes          Cliente[]        @relation("ClienteEquipo")
  productos         Producto[]       @relation("ProductoEquipo")
  cotizaciones      Cotizacion[]     @relation("CotizacionEquipo")
  contratos         Contrato[]       @relation("ContratoEquipo")
  reglas            ReglaComercial[] @relation("ReglaEquipo")
  plantillasContrato PlantillaContrato[] @relation("PlantillaContratoEmpresa")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ─── Multi-user team membership ─────────────────────────────
model EquipoMembro {
  id          String   @id @default(cuid())
  empresaId   String
  empresa     Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  usuarioId   String
  usuario     Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  rol         String   @default("SALES")  // ADMIN | SALES | VIEWER
  createdAt   DateTime @default(now())

  @@unique([empresaId, usuarioId])
  @@index([empresaId])
  @@index([usuarioId])
}

// ─── Email invitations ──────────────────────────────────────
model Invitacion {
  id            String    @id @default(cuid())
  empresaId     String
  empresa       Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  email         String
  rol           String    @default("SALES")
  token         String    @unique @default(cuid())
  expiresAt     DateTime
  usadaAt        DateTime?
  invitadoPorId  String    // userId of who sent the invite
  compartirDatos String?   // JSON array: ["clientes","productos","cotizaciones","contratos"]
  createdAt      DateTime  @default(now())

  @@index([empresaId])
  @@index([email])
  @@index([token])
}

model Usuario {
  id           String   @id @default(cuid())
  nombre       String
  email        String   @unique
  passwordHash String
  plan         String   @default("starter")   // Legacy — kept for backward compat; use empresa.plan for team plan
  rol          String   @default("admin")
  empresaId    String
  empresa      Empresa  @relation(fields: [empresaId], references: [id])
  activo       Boolean  @default(true)
  // Email verification
  emailVerified    Boolean   @default(false)
  verifyToken      String?   @unique @default(cuid())
  // Password reset
  resetToken       String?   @unique
  resetTokenExpiry DateTime?
  // Stripe subscription fields (kept for legacy; new billing via empresa)
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?
  stripePriceId        String?
  planStatus           String   @default("active") // active | past_due | canceled
  currentPeriodEnd     DateTime?
  // API Key for external integrations
  apiKeyHash           String?   @unique
  apiKeyPrefix         String?
  apiKeyCreatedAt      DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  // Relations to user-owned data
  clientes       Cliente[]
  productos      Producto[]
  cotizaciones   Cotizacion[]
  contratos      Contrato[]
  reglas         ReglaComercial[]
  memorias       MemoriaForge[]
  miembros       EquipoMembro[]
}

// Persistent memory for Forge AI assistant per user
model MemoriaForge {
  id        String   @id @default(cuid())
  usuarioId String
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  contenido String   // Fact or preference to remember, e.g. "El email del usuario es x@y.com"
  createdAt DateTime @default(now())

  @@index([usuarioId])
}

model Recordatorio {
  id             String     @id @default(cuid())
  cotizacionId   String
  cotizacion     Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  tipo           String     // SEGUIMIENTO_VENDEDOR | VENCIMIENTO_CLIENTE
  destinatario   String
  enviadoAt      DateTime   @default(now())
  createdAt      DateTime   @default(now())

  @@index([cotizacionId])
  @@index([tipo, cotizacionId])
}

model Firma {
  id             String     @id @default(cuid())
  cotizacionId   String
  cotizacion     Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  token          String     @unique @default(cuid())
  signerName     String
  signerEmail    String
  signedAt       DateTime?
  signatureData  String?
  ipAddress      String?
  createdAt      DateTime   @default(now())
  contratoId     String?
  contrato       Contrato?  @relation("FirmaContrato", fields: [contratoId], references: [id], onDelete: Cascade)

  @@index([cotizacionId])
  @@index([contratoId])
}

model Lead {
  id          String   @id @default(cuid())
  nombre      String
  email       String
  empresa     String?
  cargo       String?
  origen      String   @default("guia") // guia, blog, landing, linkedin, etc.
  recurso     String?  // which lead magnet or resource
  utmSource   String?  // utm_source (linkedin, google, blog, etc.)
  utmMedium   String?  // utm_medium (social, cpc, lead-magnet, etc.)
  utmCampaign String?  // utm_campaign (5-errores, webinar-q1, etc.)
  utmContent  String?  // utm_content (post-dolor, post-dato, etc.)
  ip          String?
  createdAt   DateTime @default(now())

  @@index([email])
  @@index([origen])
  @@index([utmSource])
}

// ==========================================
// CONTRACT MANAGEMENT
// ==========================================

model Contrato {
  id                   String    @id @default(cuid())
  numero               String
  cotizacionId         String
  cotizacion           Cotizacion @relation(fields: [cotizacionId], references: [id])
  clienteId            String
  cliente              Cliente   @relation(fields: [clienteId], references: [id])
  usuarioId            String
  usuario              Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  equipoId             String?
  equipo               Empresa?  @relation("ContratoEquipo", fields: [equipoId], references: [id])

  // State
  estado               String    @default("ACTIVO") // ACTIVO, PENDIENTE_RENOVACION, RENOVADO, CANCELADO, EXPIRADO

  // Duration
  fechaInicio          DateTime
  fechaFin             DateTime
  duracionMeses        Int       @default(12)

  // Renewal config
  renovacionAutomatica Boolean   @default(false)
  diasAvisoRenovacion  Int       @default(30)

  // Value tracking (no billing, just tracking)
  valorMensual         Float     @default(0)
  valorTotal           Float     @default(0)
  moneda               String    @default("EUR")

  // Terms
  condiciones          String?
  clausulaCancelacion  String?
  periodoPreaviso      Int       @default(30) // Days notice to cancel

  // Cancellation
  canceladoAt          DateTime?
  motivoCancelacion    String?

  // Generated document
  documentoHtml        String?
  documentoGeneradoAt  DateTime?
  plantillaId          String?

  // Relations
  lineItems            ContratoLineItem[]
  enmiendas            Enmienda[]
  actividades          ContratoActividad[]
  firmas               Firma[]   @relation("FirmaContrato")

  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@unique([numero, usuarioId])
  @@index([clienteId])
  @@index([usuarioId])
  @@index([equipoId])
  @@index([estado])
  @@index([fechaFin])
}

model ContratoLineItem {
  id             String   @id @default(cuid())
  contratoId     String
  contrato       Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  descripcion    String
  cantidad       Float    @default(1)
  precioUnitario Float
  frecuencia     String   @default("MENSUAL") // MENSUAL, TRIMESTRAL, ANUAL, UNICO
  total          Float
  orden          Int      @default(0)

  @@index([contratoId])
}

model Enmienda {
  id            String    @id @default(cuid())
  contratoId    String
  contrato      Contrato  @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  tipo          String    // MODIFICACION, UPSELL, DOWNSELL, EXTENSION, CANCELACION
  descripcion   String
  cambios       String    // JSON: what changed
  valorAnterior Float
  valorNuevo    Float
  estado        String    @default("PENDIENTE") // PENDIENTE, ACEPTADA, RECHAZADA
  token         String?   @unique @default(cuid())
  firmadoAt     DateTime?
  createdAt     DateTime  @default(now())

  @@index([contratoId])
}

model ContratoActividad {
  id          String   @id @default(cuid())
  contratoId  String
  contrato    Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  tipo        String   // CREADO, RENOVADO, ENMIENDA, CANCELADO, NOTIFICACION, ESTADO_CAMBIADO
  descripcion String
  createdAt   DateTime @default(now())

  @@index([contratoId])
}

model PlantillaContrato {
  id          String   @id @default(cuid())
  empresaId   String
  empresa     Empresa  @relation("PlantillaContratoEmpresa", fields: [empresaId], references: [id], onDelete: Cascade)
  nombre      String
  descripcion String?
  contenido   String
  esDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([empresaId])
}

// ==========================================
// BLOG & MARKETING
// ==========================================

model BlogPost {
  id          String    @id @default(cuid())
  slug        String    @unique
  titulo      String
  extracto    String    // Short excerpt for previews and meta description
  contenido   String    // Full HTML content
  imagen      String?   // Featured image URL
  autor       String    @default("DealForge")
  categoria   String    @default("general") // ventas, cpq, ia, producto, guias
  tags        String    @default("[]")      // JSON array of tags
  publicado   Boolean   @default(false)
  publishedAt DateTime?
  // SEO fields
  metaTitulo      String?  // Override for <title> tag
  metaDescripcion String?  // Override for meta description
  metaKeywords    String?  // Comma-separated keywords
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
