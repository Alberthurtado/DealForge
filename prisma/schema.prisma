generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model Cliente {
  id           String       @id @default(cuid())
  nombre       String
  ruc          String?
  email        String?
  telefono     String?
  direccion    String?
  ciudad       String?
  pais         String?
  sector       String?
  notas        String?
  usuarioId    String
  usuario      Usuario      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  contactos    Contacto[]
  cotizaciones Cotizacion[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([usuarioId])
}

model Contacto {
  id        String   @id @default(cuid())
  nombre    String
  cargo     String?
  email     String?
  telefono  String?
  principal Boolean  @default(false)
  clienteId String
  cliente   Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Categoria {
  id        String     @id @default(cuid())
  nombre    String     @unique
  productos Producto[]
}

model Producto {
  id          String              @id @default(cuid())
  nombre      String
  descripcion String?
  sku         String
  precioBase  Float
  unidad      String              @default("unidad")
  activo      Boolean             @default(true)
  categoriaId String?
  categoria   Categoria?          @relation(fields: [categoriaId], references: [id])
  usuarioId   String
  usuario     Usuario             @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  variantes   VarianteProducto[]
  lineItems   LineItem[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@unique([sku, usuarioId])
  @@index([usuarioId])
}

model VarianteProducto {
  id             String     @id @default(cuid())
  productoId     String
  producto       Producto   @relation(fields: [productoId], references: [id], onDelete: Cascade)
  nombre         String
  sku            String
  precioOverride Float?
  atributos      String     @default("{}")
  activo         Boolean    @default(true)
  lineItems      LineItem[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@unique([sku, productoId])
}

model Cotizacion {
  id               String      @id @default(cuid())
  numero           String
  clienteId        String
  cliente          Cliente     @relation(fields: [clienteId], references: [id])
  usuarioId        String
  usuario          Usuario     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  estado           String      @default("BORRADOR")
  fechaEmision     DateTime    @default(now())
  fechaVencimiento DateTime?
  contactoNombre   String?
  subtotal         Float       @default(0)
  descuentoGlobal  Float       @default(0)
  impuesto         Float       @default(0)
  total            Float       @default(0)
  moneda           String      @default("EUR")
  notas            String?
  condiciones      String?
  version          Int         @default(1)
  lineItems        LineItem[]
  actividades      Actividad[]
  aprobaciones     Aprobacion[]
  recordatorios    Recordatorio[]
  firmas           Firma[]
  cotizacionOriginalId  String?
  cotizacionOriginal    Cotizacion?  @relation("Versiones", fields: [cotizacionOriginalId], references: [id])
  versiones             Cotizacion[] @relation("Versiones")
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@unique([numero, usuarioId])
  @@index([usuarioId])
  @@index([cotizacionOriginalId])
}

model LineItem {
  id             String            @id @default(cuid())
  cotizacionId   String
  cotizacion     Cotizacion        @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  productoId     String?
  producto       Producto?         @relation(fields: [productoId], references: [id])
  varianteId     String?
  variante       VarianteProducto? @relation(fields: [varianteId], references: [id])
  descripcion    String
  cantidad       Float             @default(1)
  precioUnitario Float
  descuento      Float             @default(0)
  total          Float
  orden          Int               @default(0)
  createdAt      DateTime          @default(now())
}

model Actividad {
  id             String     @id @default(cuid())
  cotizacionId   String
  cotizacion     Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  tipo           String
  descripcion    String
  estadoAnterior String?
  estadoNuevo    String?
  createdAt      DateTime   @default(now())
}

model ReglaComercial {
  id            String   @id @default(cuid())
  nombre        String
  tipo          String   // LIMITE_DESCUENTO | PRODUCTO_OBLIGATORIO | APROBACION | PROMOCION
  activa        Boolean  @default(true)
  prioridad     Int      @default(0)
  configuracion String   // JSON text
  usuarioId     String
  usuario       Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([usuarioId])
}

model Aprobacion {
  id              String     @id @default(cuid())
  cotizacionId    String
  cotizacion      Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  reglaId         String
  aprobadorNombre String
  aprobadorEmail  String
  estado          String     @default("PENDIENTE")
  comentario      String?
  token           String?    @unique
  emailEnviadoAt  DateTime?
  respondidoAt    DateTime?
  createdAt       DateTime   @default(now())
}

model Empresa {
  id            String   @id @default("default")
  nombre        String   @default("Mi Empresa")
  cif           String?
  email         String?
  telefono      String?
  direccion     String?
  ciudad        String?
  pais          String?
  web           String?
  logoUrl       String?
  plantillaPdf      String   @default("moderna")
  colorPrimario     String   @default("#3a9bb5")
  prefijoCotizacion String   @default("COT")
  diasVencimiento   Int      @default(30)
  condicionesDefecto String?
  smtpHost          String?
  smtpPort          Int?     @default(587)
  smtpUser          String?
  smtpPass          String?
  smtpSecure        Boolean  @default(false)
  // Reminder settings
  recordatorioSeguimientoDias  Int      @default(3)
  recordatorioVencimientoDias  Int      @default(3)
  recordatoriosActivos         Boolean  @default(true)
  usuarios          Usuario[]
  createdAt         DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Usuario {
  id           String   @id @default(cuid())
  nombre       String
  email        String   @unique
  passwordHash String
  plan         String   @default("starter")
  rol          String   @default("admin")
  empresaId    String   @default("default")
  empresa      Empresa  @relation(fields: [empresaId], references: [id])
  activo       Boolean  @default(true)
  // Password reset
  resetToken       String?   @unique
  resetTokenExpiry DateTime?
  // Stripe subscription fields
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?
  stripePriceId        String?
  planStatus           String   @default("active") // active | past_due | canceled
  currentPeriodEnd     DateTime?
  // API Key for external integrations
  apiKeyHash           String?   @unique
  apiKeyPrefix         String?
  apiKeyCreatedAt      DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  // Relations to user-owned data
  clientes       Cliente[]
  productos      Producto[]
  cotizaciones   Cotizacion[]
  reglas         ReglaComercial[]
  memorias       MemoriaForge[]
}

// Persistent memory for Forge AI assistant per user
model MemoriaForge {
  id        String   @id @default(cuid())
  usuarioId String
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  contenido String   // Fact or preference to remember, e.g. "El email del usuario es x@y.com"
  createdAt DateTime @default(now())

  @@index([usuarioId])
}

model Recordatorio {
  id             String     @id @default(cuid())
  cotizacionId   String
  cotizacion     Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  tipo           String     // SEGUIMIENTO_VENDEDOR | VENCIMIENTO_CLIENTE
  destinatario   String
  enviadoAt      DateTime   @default(now())
  createdAt      DateTime   @default(now())

  @@index([cotizacionId])
  @@index([tipo, cotizacionId])
}

model Firma {
  id             String     @id @default(cuid())
  cotizacionId   String
  cotizacion     Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  token          String     @unique @default(cuid())
  signerName     String
  signerEmail    String
  signedAt       DateTime?
  signatureData  String?
  ipAddress      String?
  createdAt      DateTime   @default(now())

  @@index([cotizacionId])
}

model Lead {
  id        String   @id @default(cuid())
  nombre    String
  email     String
  empresa   String?
  cargo     String?
  origen    String   @default("guia") // guia, blog, landing, linkedin, etc.
  recurso   String?  // which lead magnet or resource
  ip        String?
  createdAt DateTime @default(now())

  @@index([email])
  @@index([origen])
}

model BlogPost {
  id          String    @id @default(cuid())
  slug        String    @unique
  titulo      String
  extracto    String    // Short excerpt for previews and meta description
  contenido   String    // Full HTML content
  imagen      String?   // Featured image URL
  autor       String    @default("DealForge")
  categoria   String    @default("general") // ventas, cpq, ia, producto, guias
  tags        String    @default("[]")      // JSON array of tags
  publicado   Boolean   @default(false)
  publishedAt DateTime?
  // SEO fields
  metaTitulo      String?  // Override for <title> tag
  metaDescripcion String?  // Override for meta description
  metaKeywords    String?  // Comma-separated keywords
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
